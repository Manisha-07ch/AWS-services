<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bus Booking</title>

<style>
body{
  font-family:Arial;
  background:#f4f7fb;
  margin:0;
}

header{
  background:#003580;
  padding:20px;
  color:white;
  text-align:center;
}

nav a{
  color:white;
  margin:15px;
  text-decoration:none;
}

.container{
  max-width:800px;
  margin:40px auto;
  background:white;
  padding:30px;
  border-radius:15px;
}

input,select,button{
  width:100%;
  padding:12px;
  margin-top:15px;
  border-radius:8px;
  border:1px solid #ccc;
}

button{
  background:#0071c2;
  color:white;
  border:none;
  font-size:18px;
}

img{
  width:100%;
  border-radius:15px;
  margin-top:20px;
}
</style>
</head>

<body>

<header>
<h1>Bus Booking</h1>

<nav>
<a href="index.html">Home</a>
<a href="hotel.html">Hotel</a>
<a href="train.html">Train</a>
</nav>
</header>

<div class="container">

<h2>Book Your Bus</h2>

<input type="text" placeholder="From City">
<input type="text" placeholder="To City">
<input type="date">

<select>
<option>Select Bus Type</option>
<option>AC Sleeper</option>
<option>Luxury Volvo</option>
<option>Non AC</option>
</select>

<button>Search Buses</button>

<img src="https://images.unsplash.com/photo-1570125909232-eb263c188f7e?q=80&w=1200&auto=format&fit=crop">

</div>
</body>
</html>

